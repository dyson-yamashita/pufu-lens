{
  "name": "pufu-lens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "turbo run build",
    "create-project": "node --experimental-strip-types scripts/create-project.ts",
    "format": "biome check --write . && prettier --write \"**/*.{md,yml,yaml}\"",
    "format:check": "biome check . && prettier --check \"**/*.{md,yml,yaml}\"",
    "lint": "biome ci . && markdownlint-cli2",
    "seed:projects": "node --experimental-strip-types scripts/create-project.ts --seed-samples",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^25.9.1",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  }
}
