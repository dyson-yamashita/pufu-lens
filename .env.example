# Application
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
PUFU_LENS_ALLOWED_DEV_ORIGINS=

# Database and storage
DATABASE_URL=postgresql://pufu_lens:pufu_lens@localhost:5432/pufu_lens
STORAGE_DRIVER=local
STORAGE_ROOT=./.data/volumes/pufu-lens-data
STORAGE_BUCKET=

# Deploy / GCP identifiers. Secret values are stored in Secret Manager, not here.
GCP_PROJECT=
GCP_REGION=asia-east1
ARTIFACT_REGISTRY_REPOSITORY=pufu-lens
MASTRA_SERVER_URL=
MASTRA_RUNTIME_SERVICE_ACCOUNT=
SCHEDULER_SERVICE_ACCOUNT=
VPC_CONNECTOR=
DATABASE_URL_SECRET=DATABASE_URL
GEMINI_API_KEY_SECRET=GEMINI_API_KEY

# Gemini / Google AI
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536

# Vertex AI alternative
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# OAuth placeholders.
# Auth.js GitHub login callback: ${AUTH_URL}/api/auth/callback/github
# Google data source callback: ${APP_BASE_URL}/api/connections/google/callback
# GitHub App setup callback: ${APP_BASE_URL}/api/connections/github/callback
# GitHub App slug, App ID, and private key are configured per project in Settings.
AUTH_SECRET=
CONNECTION_SECRET_KEY=
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_CREDENTIALS_EMAIL=
AUTH_CREDENTIALS_PASSWORD=
AUTH_CREDENTIALS_NAME=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloud Run Job / workflow-job inputs.
WORKFLOW_ID=
WORKFLOW_INPUT_JSON=
DRY_RUN=false

# Development-only bypasses. Never enable these in staging or production.
PUFU_LENS_ALLOW_FIXED_USER_FALLBACK=false
