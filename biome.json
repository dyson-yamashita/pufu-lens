{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!**/node_modules",
      "!.turbo",
      "!**/.turbo",
      "!.mastra",
      "!**/.mastra",
      "!**/.next",
      "!**/next-env.d.ts",
      "!**/dist",
      "!**/build",
      "!**/coverage",
      "!**/test-results",
      "!.data",
      "!**/.data",
      "!tmp",
      "!**/tmp",
      "!apps/web/infra",
      "!**/infra/volumes",
      "!infra/volumes",
      "!.infisical.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "includes": ["scripts/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
