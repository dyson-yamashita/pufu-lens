{
  "name": "@pufu-lens/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./chat": "./src/chat.ts",
    "./mastra-chat": "./src/mastra-chat.ts",
    "./private-chat-search": "./src/private-chat-search.ts",
    "./project-chat-settings": "./src/project-chat-settings.ts",
    "./pufu-score": "./src/pufu-score.ts",
    "./report": "./src/report.ts",
    "./test-fixtures": "./src/test-fixtures.ts"
  },
  "scripts": {
    "build": "next build",
    "dev": "DATABASE_URL=${DATABASE_URL:-postgresql://pufu_lens:pufu_lens@localhost:5432/pufu_lens} STORAGE_DRIVER=${STORAGE_DRIVER:-local} STORAGE_ROOT=${STORAGE_ROOT:-../../.data/volumes/pufu-lens-data} next dev",
    "dev:lan": "DATABASE_URL=${DATABASE_URL:-postgresql://pufu_lens:pufu_lens@localhost:5432/pufu_lens} STORAGE_DRIVER=${STORAGE_DRIVER:-local} STORAGE_ROOT=${STORAGE_ROOT:-../../.data/volumes/pufu-lens-data} next dev -H 0.0.0.0",
    "start": "next start",
    "test": "node --experimental-strip-types scripts/run-tests.ts",
    "test:db": "pnpm --filter @pufu-lens/ingestion build && node --experimental-strip-types scripts/run-db-tests.ts",
    "test:e2e": "playwright test",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@goto-lab/pufu-editor": "0.9.14",
    "@pdf-lib/fontkit": "^1.1.1",
    "@pufu-lens/ingestion": "workspace:*",
    "@pufu-lens/project-tenancy": "workspace:*",
    "@pufu-lens/storage": "workspace:*",
    "cytoscape": "^3.34.0",
    "dom-to-image": "^2.6.0",
    "google-auth-library": "9.15.1",
    "html-to-image": "^1.11.13",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "leader-line-new": "^1.1.9",
    "loglevel": "^1.9.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.6.0",
    "react-sortablejs": "^6.1.4",
    "react-textarea-autosize": "^8.5.9",
    "short-uuid": "^6.0.3",
    "sortablejs": "^1.15.7",
    "ts-interface-checker": "^1.0.2",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/dom-to-image": "2.6.7",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3"
  }
}
