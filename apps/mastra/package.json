{
  "name": "@pufu-lens/mastra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "DATABASE_URL=${DATABASE_URL:-postgresql://pufu_lens:pufu_lens@localhost:5432/pufu_lens} GOOGLE_API_KEY=${GOOGLE_API_KEY:-$GEMINI_API_KEY} GOOGLE_GENERATIVE_AI_API_KEY=${GOOGLE_GENERATIVE_AI_API_KEY:-$GEMINI_API_KEY} mastra dev",
    "mastra:build": "mastra build",
    "mastra:lint": "mastra lint",
    "test": "node --experimental-strip-types src/index.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@mastra/core": "^1.40.0",
    "@pufu-lens/storage": "workspace:*",
    "@pufu-lens/web": "workspace:*",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "mastra": "^1.11.0"
  }
}
